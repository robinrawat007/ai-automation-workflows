## Public (safe) env vars used by the frontend
## Copy to `.env.local` for local development.

# GitHub repo in "owner/name" format. Used to build raw GitHub URLs for workflow JSON files.
NEXT_PUBLIC_GITHUB_REPO=robinrawat007/ai-automation-workflows

# Optional override: base URL that serves workflow JSON files publicly.
# Example (GitHub raw):
# NEXT_PUBLIC_WORKFLOW_JSON_BASE_URL=https://raw.githubusercontent.com/robinrawat007/ai-automation-workflows/main
